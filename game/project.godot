config_version=5

[application]

config/name="SpecterRealm"
config/description="First-person endless runner survival shooter"
run/main_scene="res://scenes/main.tscn"
config/features=PackedStringArray("4.3", "Forward Plus")
config/icon="res://icon.svg"

[display]

